# Threat Intelligence API Keys (Optional - mocks will run if empty)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# AI Model Credentials (Configure one or both)
# To use OpenAI, fill in this key:
OPENAI_API_KEY=your_openai_api_key_here

# To use Ollama, run Ollama locally on your host machine and keep this host:
OLLAMA_HOST=http://host.docker.internal:11434

# Backend Service (Used inside Docker Compose)
DATABASE_URL=postgresql://peszara_admin:securepassword123@db:5432/peszara_xdr
